# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mars

# ── LLM Mode ─────────────────────────────────────────────────────────────────
# Set to "local" (default) or "cloud"
OLLAMA_MODE=local

# ── Local Ollama (OLLAMA_MODE=local) ─────────────────────────────────────────
# Pull the model first: ollama pull qwen3:1.7b
LLM_MODEL_ID=gemma4:e2b
LLAMA_SERVER_URL=http://localhost:11434/v1

# ── Ollama Cloud API (OLLAMA_MODE=cloud) ──────────────────────────────────────
# Get your key at https://ollama.com/settings/keys
# Available cloud models: gpt-oss:20b-cloud, gpt-oss:120b-cloud,
#   deepseek-v3.1:671b-cloud, qwen3-coder:480b-cloud, kimi-k2:1t-cloud
# OLLAMA_API_KEY=your_ollama_api_key_here
# LLM_MODEL_ID=gpt-oss:20b-cloud

# ── Embedding model (FAISS vector store) ─────────────────────────────────────
EMBEDDING_MODEL_NAME=google/embeddinggemma-300m
FAISS_INDEX_PATH=faiss_index
CHUNK_SIZE=200
CHUNK_OVERLAP=20

# ── CoreIoT / Thingsboard API ────────────────────────────────────────────────
COREIOT_API_BASE=https://app.coreiot.io
COREIOT_HTTP_TIMEOUT=10
COREIOT_RPC_TIMEOUT=10
COREIOT_USERNAME=aclab@mail.net
COREIOT_PASSWORD=aclab2023

# ── IoT RAG store paths ───────────────────────────────────────────────────────
# Path to the FAISS index for async-embedded conversation history
CONVERSATION_MEMORY_PATH=faiss_index/conversation_memory

# ── HuggingFace (for dataset loading only, not LLM) ──────────────────────────
# Get your token at https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here